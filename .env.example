# Glicuidado — variáveis de ambiente
#
# O app não exige segredos externos. A única configuração relevante para
# produção é o caminho do banco SQLite, que deve apontar para um volume
# persistente (já definido no docker-compose.yml).

# Caminho do banco SQLite (em produção: volume montado).
GLICUIDADO_DB_PATH=/data/glicuidado.db
